# Copy to .env for local development. Never commit real secrets.

# PostgreSQL for Prisma: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/bazaarlink?schema=public"

# Required (src/config/env.ts). HMAC secret for session JWTs (jose). Min 32 characters.
SESSION_SECRET="your-secret-at-least-32-chars-long-for-jwt"

# Not read by the current app (sessions use SESSION_SECRET); optional for tooling / future use.
# JWT_SECRET=""
# NextAuth not wired in this repo yet; set if you add next-auth.
# NEXTAUTH_SECRET=""

NODE_ENV="development"

# Optional: canonical public URL for email verification links (signup). If unset, the Host header is used.
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# prisma/seed.ts — optional; defaults documented in prisma/seed.ts if unset
# SEED_ADMIN_PASSWORD=your-admin-password
# SEED_DEMO_PASSWORD=shared-password-for-customer-and-vendor-demo-users
